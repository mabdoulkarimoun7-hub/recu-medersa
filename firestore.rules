rules_version = '2';

// Règles de sécurité Firestore — Midenty
//
// INSTRUCTIONS : Copiez ces règles dans la console Firebase :
// Console Firebase → Firestore Database → Règles → Coller → Publier
//
// Structure des données :
//   schools/{schoolCode}/students/{studentId}
//   schools/{schoolCode}/payments/{paymentId}
//   schools/{schoolCode}/meta/counters

service cloud.firestore {
  match /databases/{database}/documents {

    // Par défaut : tout est interdit
    match /{document=**} {
      allow read, write: if false;
    }

    // Données d'une école — accessibles uniquement aux utilisateurs authentifiés
    // dont le code d'accès correspond
    match /schools/{schoolCode}/{collection}/{docId} {

      // Lecture : l'utilisateur doit être authentifié
      // (le code d'accès est vérifié côté client au login)
      allow read: if request.auth != null;

      // Écriture : l'utilisateur doit être authentifié
      allow write: if request.auth != null;
    }

    // Métadonnées d'une école (compteurs)
    match /schools/{schoolCode}/meta/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
